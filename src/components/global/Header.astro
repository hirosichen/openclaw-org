---
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
  { label: '首頁', href: '/' },
  { label: '開始使用', href: '/docs/start/getting-started' },
  { label: '安裝', href: '/docs/install/install' },
  { label: '頻道', href: '/docs/channels/channels' },
  { label: '文件', href: '/docs/concepts/architecture' },
  { label: '關於', href: '/about' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 glass">
  <nav class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between" aria-label="主要導覽">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 text-lg font-bold text-text hover:text-accent transition-colors">
      <svg class="w-7 h-7 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9.5 2C6 2 4 5 4 8c0 2 1 3.5 2.5 4.5L5 17l2 5h10l2-5-1.5-4.5C19 11.5 20 10 20 8c0-3-2-6-5.5-6"/><circle cx="9" cy="8" r="1" fill="currentColor" stroke="none"/><circle cx="15" cy="8" r="1" fill="currentColor" stroke="none"/><path d="M4 8C2.5 6 1 4 2 2"/><path d="M20 8c1.5-2 3-4 2-6"/></svg>
      <span>OpenClaw <span class="text-sm font-normal text-subtext-0">台灣社群</span></span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-6">
      {navItems.map((item) => {
        const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
        return (
          <a
            href={item.href}
            class:list={[
              'text-sm font-medium transition-colors relative py-1 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:bg-accent after:transition-all after:duration-300',
              isActive ? 'text-accent after:w-full' : 'text-subtext-1 hover:text-text after:w-0 hover:after:w-full',
            ]}
            {...(isActive ? { 'aria-current': 'page' } : {})}
          >
            {item.label}
          </a>
        );
      })}
      <a
        href="https://github.com/openclaw/openclaw"
        target="_blank"
        rel="noopener noreferrer"
        class="text-subtext-1 hover:text-accent hover:scale-110 transition-all duration-200"
        aria-label="GitHub"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>
      <ThemeToggle />
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-3 -mr-2 text-subtext-1 hover:text-text hover:bg-surface-0/60 rounded-lg cursor-pointer transition-all duration-200 min-w-[48px] min-h-[48px] flex items-center justify-center active:scale-95"
      aria-label="開啟選單"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden glass border-t border-surface-0 overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0">
    <div class="px-4 py-3 space-y-1">
      {navItems.map((item) => {
        const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
        return (
          <a
            href={item.href}
            class:list={[
              'block py-3 px-3 text-sm font-medium transition-all duration-200 rounded-lg min-h-[44px] flex items-center',
              isActive ? 'text-accent bg-accent/10' : 'text-subtext-1 hover:text-text hover:bg-surface-0/60',
            ]}
            {...(isActive ? { 'aria-current': 'page' } : {})}
          >
            {item.label}
          </a>
        );
      })}
      <div class="flex items-center gap-4 pt-3 mt-1 border-t border-surface-0">
        <a
          href="https://github.com/openclaw/openclaw"
          target="_blank"
          rel="noopener noreferrer"
          class="text-subtext-1 hover:text-text transition-colors py-2"
        >
          GitHub
        </a>
        <ThemeToggle />
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('max-h-96');

    if (isOpen) {
      menu?.classList.remove('max-h-96', 'opacity-100');
      menu?.classList.add('max-h-0', 'opacity-0');
      btn?.setAttribute('aria-expanded', 'false');
    } else {
      menu?.classList.remove('max-h-0', 'opacity-0');
      menu?.classList.add('max-h-96', 'opacity-100');
      btn?.setAttribute('aria-expanded', 'true');
    }
  });
</script>
