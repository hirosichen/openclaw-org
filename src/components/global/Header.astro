---
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
  { label: '首頁', href: '/' },
  { label: '文件', href: '/docs/getting-started/installation' },
  { label: '關於', href: '/about' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 glass">
  <nav class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 text-lg font-bold text-text hover:text-accent transition-colors">
      <span class="text-accent text-2xl">🦞</span>
      <span>OpenClaw <span class="text-sm font-normal text-subtext-0">台灣社群</span></span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-6">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'text-sm font-medium transition-colors',
            currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
              ? 'text-accent'
              : 'text-subtext-1 hover:text-text',
          ]}
        >
          {item.label}
        </a>
      ))}
      <a
        href="https://github.com/nickthecook/openclaw"
        target="_blank"
        rel="noopener noreferrer"
        class="text-subtext-1 hover:text-text transition-colors"
        aria-label="GitHub"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>
      <ThemeToggle />
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-subtext-1 hover:text-text cursor-pointer"
      aria-label="開啟選單"
    >
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden glass border-t border-surface-0">
    <div class="px-4 py-3 space-y-2">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'block py-2 text-sm font-medium transition-colors',
            currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
              ? 'text-accent'
              : 'text-subtext-1 hover:text-text',
          ]}
        >
          {item.label}
        </a>
      ))}
      <div class="flex items-center gap-4 pt-2 border-t border-surface-0">
        <a
          href="https://github.com/nickthecook/openclaw"
          target="_blank"
          rel="noopener noreferrer"
          class="text-subtext-1 hover:text-text transition-colors"
        >
          GitHub
        </a>
        <ThemeToggle />
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
