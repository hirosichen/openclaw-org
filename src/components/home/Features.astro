---
import { features } from '../../data/features';

const colors = ['text-green', 'text-blue', 'text-peach', 'text-yellow', 'text-mauve', 'text-teal'];
---

<section class="py-16 px-4 relative">
  <!-- Subtle background -->
  <div class="absolute inset-0 bg-mantle/50 -z-10"></div>
  <div class="absolute inset-0 dot-grid opacity-20 -z-10"></div>

  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-text mb-3 animate-on-scroll">核心功能</h2>
    <p class="text-center text-subtext-0 max-w-2xl mx-auto mb-10 animate-on-scroll">
      OpenClaw 提供豐富的功能，讓你打造專屬的 AI 助理體驗。
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 stagger-children">
      {features.map((feature, i) => (
        <div class="group glass rounded-xl p-6 transition-all duration-300 hover:scale-[1.02] hover:shadow-xl hover:border-accent/30">
          <div class="text-4xl mb-4 transition-transform duration-300 group-hover:scale-110">{feature.icon}</div>
          <h3 class:list={['text-lg font-bold mb-2', colors[i % colors.length]]}>{feature.title}</h3>
          <p class="text-sm text-subtext-0 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
