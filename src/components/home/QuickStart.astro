---
import Button from '../ui/Button.astro';

const steps = [
  {
    step: '1',
    title: '安裝 OpenClaw',
    code: 'npm install openclaw@latest',
  },
  {
    step: '2',
    title: '新手引導與安裝服務',
    code: 'openclaw onboard --install-daemon',
  },
  {
    step: '3',
    title: '配對 WhatsApp 並啟動閘道器',
    code: 'openclaw channels login\nopenclaw gateway --port 18789',
  },
];
---

<section class="py-16 px-4 relative cv-auto">
  <div class="absolute inset-0 bg-mantle/50 -z-10"></div>

  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-text mb-3 animate-on-scroll section-heading">快速開始</h2>
    <p class="text-center text-subtext-0 mb-10 animate-on-scroll">
      只需三個步驟，即可在你的電腦上啟動 AI 代理閘道器。
    </p>

    <div class="relative stagger-children">
      {/* Vertical connector line */}
      <div class="absolute left-[1.5rem] sm:left-[calc(1.5rem+1rem)] top-[2.5rem] bottom-[2.5rem] w-px bg-gradient-to-b from-accent/40 via-accent/20 to-accent/40 hidden sm:block"></div>

      <div class="space-y-5">
        {steps.map((s, i) => (
          <div class="glass rounded-xl p-6 transition-all duration-300 hover:border-accent/30 hover:shadow-lg hover:-translate-y-0.5">
            <div class="flex items-center gap-4 mb-3">
              <span class="relative z-10 flex-shrink-0 w-10 h-10 bg-accent text-white rounded-full flex items-center justify-center text-sm font-bold shadow-lg shadow-accent/25 ring-4 ring-accent/15">
                {s.step}
              </span>
              <h3 class="text-lg font-bold text-text">{s.title}</h3>
            </div>
            <pre class="bg-crust rounded-lg p-4 overflow-x-auto border border-surface-0/60 border-l-4 border-l-accent/40"><code class="text-sm font-mono text-green leading-relaxed">{s.code}</code></pre>
          </div>
        ))}
      </div>
    </div>

    <div class="text-center mt-10 animate-on-scroll">
      <Button href="/docs/install/install" variant="primary" size="lg">
        查看完整安裝指南 →
      </Button>
    </div>
  </div>
</section>
