---
import Button from '../ui/Button.astro';
---

<section class="py-16 px-4">
  <div class="max-w-3xl mx-auto text-center animate-on-scroll">
    <div class="relative glass rounded-2xl p-10 md:p-14 overflow-hidden">
      <!-- Decorative glow -->
      <div class="absolute -top-20 -right-20 w-40 h-40 bg-accent/10 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-20 -left-20 w-40 h-40 bg-mauve/10 rounded-full blur-3xl"></div>

      <div class="relative">
        <h2 class="text-3xl font-bold text-text mb-4">加入台灣社群</h2>
        <p class="text-subtext-0 mb-8 max-w-lg mx-auto leading-relaxed">
          與其他台灣的 OpenClaw 使用者交流心得、分享設定、回報問題，一起打造更好的 AI 助理體驗。
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button href="https://github.com/nickthecook/openclaw" variant="primary" size="lg">
            GitHub 討論區
          </Button>
          <Button href="/docs/getting-started/installation" variant="secondary" size="lg">
            開始使用
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>
