---
const channels = [
  { name: 'LINE', icon: '💚', priority: true, slug: 'line' },
  { name: 'Telegram', icon: '✈️', priority: false, slug: 'telegram' },
  { name: 'WhatsApp', icon: '📱', priority: false, slug: 'whatsapp' },
  { name: 'Discord', icon: '🎮', priority: false, slug: 'discord' },
  { name: 'Signal', icon: '🔵', priority: false, slug: 'signal' },
  { name: 'Slack', icon: '💼', priority: false, slug: 'slack' },
  { name: 'Messenger', icon: '💬', priority: false, slug: 'messenger' },
  { name: 'WeChat', icon: '🟢', priority: false, slug: '' },
];
---

<section class="py-16 px-4">
  <div class="max-w-6xl mx-auto text-center">
    <h2 class="text-3xl font-bold text-text mb-3 animate-on-scroll">支援的聊天頻道</h2>
    <p class="text-subtext-0 max-w-2xl mx-auto mb-10 animate-on-scroll">
      透過你已經在使用的聊天 App 與 AI 助理互動，無需額外安裝。
    </p>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 max-w-3xl mx-auto stagger-children">
      {channels.map((ch) => {
        const Tag = ch.slug ? 'a' : 'div';
        const href = ch.slug ? `/docs/channels/${ch.slug}` : undefined;
        return (
          <Tag
            href={href}
            class:list={[
              'group glass rounded-xl p-5 text-center transition-all duration-300 hover:scale-[1.04] block',
              ch.priority
                ? 'ring-2 ring-accent/40 hover:ring-accent hover:shadow-lg hover:shadow-accent/10'
                : 'hover:border-accent/30 hover:shadow-lg',
            ]}
          >
            <div class="text-3xl mb-2 transition-transform duration-300 group-hover:scale-125">{ch.icon}</div>
            <div class="text-sm font-medium text-text">{ch.name}</div>
            {ch.priority && (
              <span class="inline-block mt-1 text-xs text-accent font-medium">推薦</span>
            )}
            {ch.slug && (
              <div class="mt-2 text-xs text-overlay-0 opacity-0 group-hover:opacity-100 transition-opacity">
                查看文件 →
              </div>
            )}
          </Tag>
        );
      })}
    </div>
  </div>
</section>
