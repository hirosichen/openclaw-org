---
// SVG icons for each channel - clean monochrome stroke style
const channelIcons: Record<string, string> = {
  // WhatsApp - phone with chat bubble
  whatsapp: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>`,
  // Telegram - paper plane
  telegram: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>`,
  // Discord - game controller
  discord: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>`,
  // iMessage - chat bubble
  imessage: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  // LINE - chat with ellipsis
  line: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><line x1="8" y1="10" x2="8.01" y2="10"/><line x1="12" y1="10" x2="12.01" y2="10"/><line x1="16" y1="10" x2="16.01" y2="10"/></svg>`,
  // Signal - shield with lock
  signal: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  // Slack - hash
  slack: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/></svg>`,
  // Matrix - brackets
  matrix: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 7 4 4 20 4 20 7"/><polyline points="4 17 4 20 20 20 20 17"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/><line x1="9" y1="15" x2="9.01" y2="15"/><line x1="15" y1="15" x2="15.01" y2="15"/></svg>`,
  // Mattermost - users/team
  mattermost: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  // MS Teams - grid
  msteams: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>`,
  // Google Chat - chat dots
  googlechat: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22z"/><line x1="8" y1="12" x2="8.01" y2="12"/><line x1="12" y1="12" x2="12.01" y2="12"/><line x1="16" y1="12" x2="16.01" y2="12"/></svg>`,
  // IRC - terminal
  irc: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>`,
};

const channels = [
  { name: 'WhatsApp', key: 'whatsapp', priority: true, slug: 'whatsapp' },
  { name: 'Telegram', key: 'telegram', priority: true, slug: 'telegram' },
  { name: 'Discord', key: 'discord', priority: true, slug: 'discord' },
  { name: 'iMessage', key: 'imessage', priority: true, slug: 'imessage' },
  { name: 'LINE', key: 'line', priority: false, slug: 'line' },
  { name: 'Signal', key: 'signal', priority: false, slug: 'signal' },
  { name: 'Slack', key: 'slack', priority: false, slug: 'slack' },
  { name: 'Matrix', key: 'matrix', priority: false, slug: 'matrix' },
  { name: 'Mattermost', key: 'mattermost', priority: false, slug: 'mattermost' },
  { name: 'MS Teams', key: 'msteams', priority: false, slug: 'msteams' },
  { name: 'Google Chat', key: 'googlechat', priority: false, slug: 'googlechat' },
  { name: 'IRC', key: 'irc', priority: false, slug: 'irc' },
];
---

<section class="py-16 px-4 cv-auto">
  <div class="max-w-6xl mx-auto text-center">
    <h2 class="text-3xl font-bold text-text mb-3 animate-on-scroll section-heading">支援的聊天頻道</h2>
    <p class="text-subtext-0 max-w-2xl mx-auto mb-10 animate-on-scroll">
      透過你已經在使用的聊天 App 與 AI 助理互動，無需額外安裝。
    </p>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 max-w-3xl mx-auto stagger-children">
      {channels.map((ch) => {
        const Tag = ch.slug ? 'a' : 'div';
        const href = ch.slug ? `/docs/channels/${ch.slug}` : undefined;
        return (
          <Tag
            href={href}
            class:list={[
              'group glass rounded-xl p-5 text-center transition-all duration-300 hover:scale-[1.04] hover:-translate-y-1 block',
              ch.priority
                ? 'ring-2 ring-accent/40 hover:ring-accent hover:shadow-xl hover:shadow-accent/15'
                : 'hover:border-accent/30 hover:shadow-lg',
            ]}
          >
            <div class="flex justify-center mb-2.5 text-subtext-0 transition-all duration-300 group-hover:text-accent group-hover:scale-110 group-hover:drop-shadow-lg" set:html={channelIcons[ch.key]} />
            <div class="text-sm font-medium text-text">{ch.name}</div>
            {ch.priority && (
              <span class="inline-block mt-1.5 text-[10px] text-accent font-semibold tracking-wide uppercase px-2 py-0.5 rounded-full bg-accent/10 border border-accent/20">推薦</span>
            )}
            {ch.slug && (
              <div class="mt-2 text-xs text-overlay-0 opacity-0 group-hover:opacity-100 transition-opacity">
                查看文件 →
              </div>
            )}
          </Tag>
        );
      })}
    </div>
  </div>
</section>
