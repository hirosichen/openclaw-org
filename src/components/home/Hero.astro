---
import Button from '../ui/Button.astro';
---

<section class="relative overflow-hidden py-20 md:py-28">
  <!-- Animated gradient background -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-gradient-to-br from-accent/10 via-base to-mauve/10"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-accent/5 rounded-full blur-3xl animate-pulse" style="animation-duration: 4s;"></div>
    <div class="absolute top-1/4 right-1/4 w-[300px] h-[300px] bg-mauve/5 rounded-full blur-3xl animate-pulse" style="animation-duration: 6s; animation-delay: 1s;"></div>
    <!-- Dot grid overlay -->
    <div class="absolute inset-0 dot-grid opacity-30"></div>
  </div>

  <div class="max-w-4xl mx-auto px-4 text-center">
    <div class="text-6xl mb-6 animate-on-scroll" style="animation-delay: 0ms;">🦞</div>
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight mb-6 animate-on-scroll" style="animation-delay: 100ms;">
      <span class="text-text">OpenClaw</span>
      <br />
      <span class="bg-gradient-to-r from-accent to-peach bg-clip-text text-transparent">AI 代理的跨平台聊天閘道器</span>
    </h1>
    <p class="text-lg md:text-xl text-subtext-0 max-w-2xl mx-auto mb-10 leading-relaxed animate-on-scroll" style="animation-delay: 200ms;">
      跨 WhatsApp、Telegram、Discord、iMessage 等聊天 App 的作業系統級 AI 代理閘道器。
      傳送訊息，從口袋中取得代理回應。自架、開源、MIT 授權。
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center animate-on-scroll" style="animation-delay: 300ms;">
      <Button href="/docs/start/getting-started" variant="primary" size="lg">
        開始使用 →
      </Button>
      <Button href="https://github.com/openclaw/openclaw" variant="secondary" size="lg">
        GitHub 原始碼
      </Button>
    </div>
  </div>

  <!-- Fade into next section -->
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-base to-transparent"></div>
</section>
