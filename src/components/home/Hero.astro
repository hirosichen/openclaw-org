---
import Button from '../ui/Button.astro';
---

<section class="relative overflow-hidden pt-12 pb-16 md:pt-24 md:pb-28">
  <!-- Animated gradient background -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-gradient-to-br from-accent/8 via-base to-mauve/8"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-accent/5 rounded-full blur-3xl animate-pulse will-change-transform" style="animation-duration: 4s; contain: strict;"></div>
    <div class="absolute top-1/4 right-1/4 w-[250px] h-[250px] bg-mauve/5 rounded-full blur-3xl animate-pulse will-change-transform" style="animation-duration: 6s; animation-delay: 1s; contain: strict;"></div>
    <!-- Dot grid overlay -->
    <div class="absolute inset-0 dot-grid opacity-20"></div>
  </div>

  <div class="max-w-4xl mx-auto px-4 text-center">
    <!-- Version badge -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-surface-0/60 bg-surface-0/20 text-xs text-subtext-0 mb-8 animate-on-scroll transition-all duration-300 hover:border-accent/40 hover:shadow-lg hover:shadow-accent/10 cursor-default" style="animation-delay: 0ms;">
      <span class="w-2 h-2 rounded-full bg-green animate-pulse shadow-md shadow-green/40"></span>
      開源專案 · MIT 授權
    </div>

    <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold tracking-tight mb-5 md:mb-6 animate-on-scroll leading-[1.25] md:leading-[1.15]" style="animation-delay: 80ms;">
      <span class="text-text">OpenClaw</span>
      <br />
      <span class="bg-gradient-to-r from-accent via-peach to-accent bg-[length:200%_auto] bg-clip-text text-transparent drop-shadow-sm animate-gradient-sweep">AI 代理的跨平台聊天閘道器</span>
    </h1>
    <p class="text-base md:text-xl text-subtext-1 max-w-2xl mx-auto mb-8 md:mb-10 leading-[1.75] animate-on-scroll px-2 md:px-0" style="animation-delay: 160ms;">
      跨 WhatsApp、Telegram、Discord、iMessage 等聊天 App 的作業系統級 AI 代理閘道器。傳送訊息，從口袋中取得代理回應。
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center animate-on-scroll" style="animation-delay: 240ms;">
      <Button href="/docs/start/getting-started" variant="primary" size="lg">
        開始使用 →
      </Button>
      <Button href="https://github.com/openclaw/openclaw" variant="secondary" size="lg">
        GitHub 原始碼
      </Button>
    </div>

    <!-- Tech stack tags -->
    <div class="flex flex-wrap items-center justify-center gap-3 mt-10 animate-on-scroll" style="animation-delay: 320ms;">
      <span class="text-xs text-overlay-0 font-mono px-2.5 py-1 rounded border border-surface-0/40 bg-surface-0/10 transition-all duration-300 hover:border-accent/30 hover:bg-surface-0/20 hover:-translate-y-0.5 hover:shadow-sm cursor-default">Node 22+</span>
      <span class="text-xs text-overlay-0 font-mono px-2.5 py-1 rounded border border-surface-0/40 bg-surface-0/10 transition-all duration-300 hover:border-accent/30 hover:bg-surface-0/20 hover:-translate-y-0.5 hover:shadow-sm cursor-default">自架部署</span>
      <span class="text-xs text-overlay-0 font-mono px-2.5 py-1 rounded border border-surface-0/40 bg-surface-0/10 transition-all duration-300 hover:border-accent/30 hover:bg-surface-0/20 hover:-translate-y-0.5 hover:shadow-sm cursor-default">多頻道</span>
      <span class="text-xs text-overlay-0 font-mono px-2.5 py-1 rounded border border-surface-0/40 bg-surface-0/10 transition-all duration-300 hover:border-accent/30 hover:bg-surface-0/20 hover:-translate-y-0.5 hover:shadow-sm cursor-default">多代理</span>
    </div>
  </div>

  <!-- Fade into next section -->
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-base to-transparent hero-fade"></div>
</section>
