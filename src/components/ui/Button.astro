---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { href, variant = 'primary', size = 'md', class: className } = Astro.props;

const Tag = href ? 'a' : 'button';

const baseClasses = 'inline-flex items-center justify-center font-medium rounded-lg transition-all duration-200 cursor-pointer select-none focus-visible:outline-2 focus-visible:outline-offset-3 focus-visible:outline-accent active:scale-[0.97] active:duration-75';

const variants = {
  primary: 'bg-accent text-white hover:bg-accent-hover hover:shadow-xl hover:shadow-accent/25 hover:-translate-y-0.5 shadow-lg shadow-accent/20',
  secondary: 'glass text-text hover:text-accent hover:border-accent/50 hover:shadow-lg hover:-translate-y-0.5',
  ghost: 'text-subtext-1 hover:text-text hover:bg-surface-0/80',
};

const sizes = {
  sm: 'px-3 py-1.5 text-sm min-h-[36px]',
  md: 'px-5 py-2.5 text-sm min-h-[44px]',
  lg: 'px-7 py-3 text-base min-h-[48px]',
};
---

<Tag
  href={href}
  class:list={[baseClasses, variants[variant], sizes[size], className]}
>
  <slot />
</Tag>
