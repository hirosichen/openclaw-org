---
import { docsNavigation } from '../../data/navigation';

interface Props {
  currentSlug: string;
  title: string;
}

const { currentSlug, title } = Astro.props;

// Find the section for this slug
const section = docsNavigation.find((s) =>
  s.items.some((item) => item.slug === currentSlug)
);
---

<nav class="text-sm text-subtext-0 mb-6" aria-label="麵包屑">
  <ol class="flex items-center gap-1.5 flex-wrap" itemscope itemtype="https://schema.org/BreadcrumbList">
    <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <a href="/" itemprop="item" class="hover:text-accent transition-colors"><span itemprop="name">首頁</span></a>
      <meta itemprop="position" content="1" />
    </li>
    <li class="text-overlay-0" aria-hidden="true">/</li>
    <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <a href="/docs/start/getting-started" itemprop="item" class="hover:text-accent transition-colors"><span itemprop="name">文件</span></a>
      <meta itemprop="position" content="2" />
    </li>
    {section && (
      <>
        <li class="text-overlay-0" aria-hidden="true">/</li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span itemprop="name" class="text-subtext-1">{section.label}</span>
          <meta itemprop="position" content="3" />
        </li>
      </>
    )}
    <li class="text-overlay-0" aria-hidden="true">/</li>
    <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <span itemprop="name" class="text-text font-medium" aria-current="page">{title}</span>
      <meta itemprop="position" content={section ? '4' : '3'} />
    </li>
  </ol>
</nav>
