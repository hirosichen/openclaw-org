---
interface Props {
  type?: 'info' | 'tip' | 'warning' | 'danger';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const config = {
  info: { icon: 'ℹ️', bg: 'bg-blue/10', border: 'border-blue/30', titleColor: 'text-blue' },
  tip: { icon: '💡', bg: 'bg-green/10', border: 'border-green/30', titleColor: 'text-green' },
  warning: { icon: '⚠️', bg: 'bg-yellow/10', border: 'border-yellow/30', titleColor: 'text-yellow' },
  danger: { icon: '🚨', bg: 'bg-accent/10', border: 'border-accent/30', titleColor: 'text-accent' },
};

const c = config[type];
---

<div class:list={['rounded-lg border-l-4 p-4 my-6', c.bg, c.border]}>
  {title && (
    <div class:list={['flex items-center gap-2 font-bold text-sm mb-2', c.titleColor]}>
      <span>{c.icon}</span>
      <span>{title}</span>
    </div>
  )}
  <div class="text-sm text-subtext-1 leading-relaxed [&>p]:my-0">
    <slot />
  </div>
</div>
