---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  mobile?: boolean;
}

const { headings, mobile = false } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && mobile && (
  <details class="xl:hidden mb-6 glass rounded-lg group" id="mobile-toc">
    <summary class="flex items-center justify-between px-4 py-3 cursor-pointer text-sm font-medium text-subtext-0 hover:text-text transition-colors select-none min-h-[44px] list-none [&::-webkit-details-marker]:hidden">
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
        目錄
        <span class="text-[10px] text-overlay-0 tabular-nums">({filteredHeadings.filter(h => h.depth === 2).length} 節)</span>
      </span>
      <svg class="w-4 h-4 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
    </summary>
    <ul class="px-4 pb-3 space-y-0.5 text-sm border-t border-surface-0/40">
      {filteredHeadings.map((h) => (
        <li>
          <a
            href={`#${h.slug}`}
            class:list={[
              'toc-link block transition-colors duration-200 hover:text-accent py-1.5 min-h-[36px] flex items-center',
              h.depth === 2 ? 'text-subtext-0 font-medium' : 'text-overlay-1 text-xs pl-4',
            ]}
          >
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </details>
  <script>
    const mobileToc = document.getElementById('mobile-toc');
    mobileToc?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileToc.removeAttribute('open');
      });
    });
  </script>
)}

{filteredHeadings.length > 0 && !mobile && (
  <div class="hidden xl:block w-56 shrink-0">
    <div class="sticky top-20 max-h-[calc(100vh-6rem)] overflow-y-auto scroll-smooth toc-scrollbar">
      <div class="flex items-center justify-between mb-3">
        <h4 class="text-xs font-bold uppercase tracking-wider text-overlay-0">目錄</h4>
        <span class="text-[10px] text-overlay-0 tabular-nums">{filteredHeadings.filter(h => h.depth === 2).length} 節</span>
      </div>
      <ul class="space-y-0.5 text-sm border-l border-surface-0">
        {filteredHeadings.map((h) => (
          <li>
            <a
              href={`#${h.slug}`}
              class:list={[
                'toc-link block transition-all duration-300 hover:text-accent hover:bg-surface-0/30 rounded-r-md border-l-2 border-transparent -ml-[2px] py-1',
                h.depth === 2 ? 'pl-3 text-subtext-0' : 'pl-6 text-overlay-1 text-xs',
              ]}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
)}
