---
import PageLayout from '../layouts/PageLayout.astro';
import Button from '../components/ui/Button.astro';
---

<PageLayout title="找不到頁面" description="頁面不存在" noindex>
  <div class="flex flex-col items-center justify-center min-h-[60vh] px-4 text-center">
    <div class="mb-6 text-accent">
      <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M16 16s-1.5-2-4-2-4 2-4 2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
    </div>
    <h1 class="text-5xl font-bold text-text mb-4">404</h1>
    <p class="text-xl text-subtext-0 mb-8">
      哎呀！這個頁面好像被龍蝦夾走了。
    </p>
    <div class="flex gap-4">
      <Button href="/" variant="primary" size="lg">
        回到首頁
      </Button>
      <Button href="/docs/start/getting-started" variant="secondary" size="lg">
        瀏覽文件
      </Button>
    </div>
  </div>
</PageLayout>
