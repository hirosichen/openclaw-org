---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import Disclaimer from '../components/global/Disclaimer.astro';
import DocSidebar from '../components/docs/DocSidebar.astro';
import DocBreadcrumb from '../components/docs/DocBreadcrumb.astro';
import DocTOC from '../components/docs/DocTOC.astro';
import DocPagination from '../components/docs/DocPagination.astro';
import Callout from '../components/docs/Callout.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  slug: string;
  headings: Heading[];
  officialDoc?: string;
}

const { title, description, slug, headings, officialDoc } = Astro.props;

// Find section label for breadcrumb
import { docsNavigation } from '../data/navigation';
const section = docsNavigation.find((s) =>
  s.items.some((item) => item.slug === slug)
);

// JSON-LD: BreadcrumbList schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: '首頁',
      item: Astro.site?.toString(),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: '文件',
      item: new URL('/docs/start/getting-started', Astro.site).toString(),
    },
    ...(section ? [{
      '@type': 'ListItem',
      position: 3,
      name: section.label,
    }] : []),
    {
      '@type': 'ListItem',
      position: section ? 4 : 3,
      name: title,
      item: new URL(`/docs/${slug}`, Astro.site).toString(),
    },
  ],
};

// JSON-LD: TechArticle schema for documentation pages
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: title,
  description: description,
  url: new URL(`/docs/${slug}`, Astro.site).toString(),
  inLanguage: 'zh-TW',
  publisher: {
    '@type': 'Organization',
    name: 'OpenClaw 台灣社群',
    url: Astro.site?.toString(),
  },
  ...(officialDoc ? { isBasedOn: officialDoc } : {}),
};

// JSON-LD: FAQPage schema (only for FAQ page)
const isFaqPage = slug === 'help/faq';
const faqSchema = isFaqPage ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'OpenClaw 的系統需求是什麼？',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '需要 Node.js >= 22，可在 Raspberry Pi 上執行（個人使用最低 512MB-1GB RAM）。可透過 npm 或安裝腳本安裝，入門設定通常需要 5-15 分鐘。',
      },
    },
    {
      '@type': 'Question',
      name: 'OpenClaw 支援哪些聊天平台？',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'OpenClaw 支援 20+ 聊天頻道，包括 WhatsApp、Telegram、Discord、iMessage、LINE、Signal、Slack、Matrix、Mattermost、Microsoft Teams、Google Chat、飛書、IRC、Nostr、Twitch 等。',
      },
    },
    {
      '@type': 'Question',
      name: 'OpenClaw 的資料存儲在哪裡？',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '狀態存放在 ~/.openclaw（設定、憑證、工作階段），Agent 工作空間預設為 ~/.openclaw/workspace，記憶持久化在 markdown 檔案中。',
      },
    },
    {
      '@type': 'Question',
      name: 'OpenClaw Gateway 的預設設定是什麼？',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '預設連接埠為 18789，預設啟用 token 驗證（即使在 localhost 上），非 loopback 繫結需要設定驗證，支援熱重載大多數設定變更。',
      },
    },
    {
      '@type': 'Question',
      name: 'OpenClaw 支援多 Agent 嗎？',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '是的，單一 Gateway 可託管多個 agent，每個 agent 維護獨立的工作空間和工作階段歷史，可實現每個 agent 的專業化工作流程。',
      },
    },
    {
      '@type': 'Question',
      name: '最佳部署方式是什麼？',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '筆電/桌機適合主動使用，VPS 適合全天候可靠性，Mac mini 作為常駐主機搭配 node 周邊裝置，Windows 使用者建議使用 WSL2。',
      },
    },
  ],
} : null;

// JSON-LD: HowTo schema (only for getting-started page)
const isGettingStarted = slug === 'start/getting-started';
const howToSchema = isGettingStarted ? {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: '如何安裝並設定 OpenClaw',
  description: '從零開始到首次對話的最簡設定指南，5 分鐘即可完成。',
  totalTime: 'PT5M',
  tool: [
    { '@type': 'HowToTool', name: 'Node.js 22+' },
    { '@type': 'HowToTool', name: '終端機 (Terminal)' },
  ],
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: '安裝 OpenClaw',
      text: '在 macOS/Linux 上執行 curl -fsSL https://openclaw.ai/install.sh | bash，或在 Windows PowerShell 上執行 iwr -useb https://openclaw.ai/install.ps1 | iex。',
      url: new URL('/docs/start/getting-started#步驟-1安裝-openclaw建議方式', Astro.site).toString(),
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: '執行引導精靈',
      text: '執行 openclaw onboard --install-daemon，精靈會設定認證、Gateway 設定以及選用的頻道。',
      url: new URL('/docs/start/getting-started#步驟-2執行引導精靈', Astro.site).toString(),
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: '檢查 Gateway',
      text: '執行 openclaw gateway status 確認 Gateway 已在執行中。',
      url: new URL('/docs/start/getting-started#步驟-3檢查-gateway', Astro.site).toString(),
    },
    {
      '@type': 'HowToStep',
      position: 4,
      name: '開啟 Control UI',
      text: '執行 openclaw dashboard 開啟瀏覽器控制介面，確認 Gateway 已準備就緒。',
      url: new URL('/docs/start/getting-started#步驟-4開啟-control-ui', Astro.site).toString(),
    },
  ],
} : null;
---

<BaseLayout title={title} description={description} ogType="article">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  {howToSchema && <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />}
  <Disclaimer />
  <Header />
  <div class="flex-1 max-w-[90rem] mx-auto w-full flex">
    <DocSidebar currentSlug={slug} />

    <main class="flex-1 min-w-0 px-4 py-8 lg:px-8">
      <DocBreadcrumb currentSlug={slug} title={title} />

      {officialDoc && (
        <Callout type="info" title="翻譯文件">
          <p>
            本頁為社群翻譯版本，可能與官方最新內容有出入。
            <a href={officialDoc} target="_blank" rel="noopener noreferrer" class="text-blue hover:underline">
              查看官方英文原文 →
            </a>
          </p>
        </Callout>
      )}

      <article class="prose prose-invert max-w-none
        prose-headings:text-text prose-headings:font-bold
        prose-p:text-subtext-1 prose-p:leading-relaxed
        prose-a:text-accent prose-a:no-underline hover:prose-a:underline
        prose-strong:text-text
        prose-code:text-peach
        prose-li:text-subtext-1
        prose-blockquote:border-accent prose-blockquote:text-subtext-0
      ">
        <h1 class="text-3xl mb-2">{title}</h1>
        <p class="text-subtext-0 text-lg mt-0 mb-8">{description}</p>
        <slot />
      </article>

      <DocPagination currentSlug={slug} />
    </main>

    <DocTOC headings={headings} />
  </div>
  <Footer />
</BaseLayout>
